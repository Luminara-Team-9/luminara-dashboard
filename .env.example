# ==============================================================================
# LUMINARA MASTER ENVIRONMENT TEMPLATE
# ==============================================================================
# Instructions for the Team:
# 1. Copy this file and rename it to `.env` in your local root directory.
# 2. Ask the Tech Lead for the actual production passwords/keys.
# 3. NEVER commit your actual `.env` file to version control (check .gitignore).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. GLOBAL SYSTEM CONFIGURATION
# ------------------------------------------------------------------------------
# Set to 'development' for local/PR testing, 'production' for live deployments.
APP_ENV=development 
# The IP address of the host server (e.g., ABRM02 internal IP or localhost)
HOST_IP=127.0.0.1 

# ------------------------------------------------------------------------------
# 2. POSTGRESQL DATABASE
# ------------------------------------------------------------------------------
# Ports -> Production: 5432 | Development: 5433
POSTGRES_USER=luminara_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=luminara_metrics
PGPORT=5433

# Connection string used by LHCI and the AI Agent to reach the database
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${HOST_IP}:${PGPORT}/${POSTGRES_DB}"

# ------------------------------------------------------------------------------
# 3. LHCI SERVER (Telemetry Sink)
# ------------------------------------------------------------------------------
# Ports -> Production: 9001 | Development: 9002
LHCI_PORT=9002
# The URL where the auditor sends JSON payloads
LHCI_SERVER_URL="http://${HOST_IP}:${LHCI_PORT}"
# Generated via `lhci wizard` to authorize secure data uploads
LHCI_BUILD_TOKEN=your_secure_project_token_here

# ------------------------------------------------------------------------------
# 4. WEB DASHBOARD (Next.js)
# ------------------------------------------------------------------------------
# Ports -> Production: 3000 | Development: 3001
PORT=3001
NEXT_PUBLIC_APP_URL="http://${HOST_IP}:${PORT}"
# Backend API used by the dashboard BFF route. If unavailable, the dashboard falls
# back to mock data instead of failing the UI.
DASHBOARD_PERFORMANCE_API_URL="http://${HOST_IP}:4000/dashboard/performance"
# Expose the LHCI server URL to the frontend for viewing performance dashboards
NEXT_PUBLIC_LHCI_DASHBOARD_URL="http://${HOST_IP}:${LHCI_PORT}/app"

# Dashboard Backend API container
DASHBOARD_API_HOST=0.0.0.0
DASHBOARD_API_PORT=4000

# Optional: NextAuth/Auth.js Secrets if implementing user logins
# NEXTAUTH_URL="http://${HOST_IP}:${PORT}"
# NEXTAUTH_SECRET=generate_a_random_base64_string

# ------------------------------------------------------------------------------
# 5. EPHEMERAL AUDITOR
# ------------------------------------------------------------------------------
# The default URL the ephemeral container targets when spun up by GitHub Actions
TARGET_URL="http://${HOST_IP}:${PORT}"

# ------------------------------------------------------------------------------
# 6. AI & AGENTIC WORKFLOWS (LangGraph + vLLM)
# ------------------------------------------------------------------------------
# Local vLLM Inference Server (Requires Driver 525 compatibility)
VLLM_API_BASE="http://${HOST_IP}:8000/v1"
VLLM_API_KEY=local_server_token_if_configured

# Fallback/External API Keys (If local hardware is fully utilized)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
# Tracing for LangGraph workflows (Highly recommended for debugging the AI Agent)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...

# ------------------------------------------------------------------------------
# 7. INFRASTRUCTURE & RUM STACK (Redis & ClickHouse)
# ------------------------------------------------------------------------------
# Message Queue for Team Task Sharing & Agent memory
REDIS_URL="redis://${HOST_IP}:6379"

# Real User Monitoring (RUM) Telemetry Database
CLICKHOUSE_HOST=${HOST_IP}
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password

# ------------------------------------------------------------------------------
# 8. AI MODEL CONFIGURATION 
# ------------------------------------------------------------------------------
# Qwen model path — only required on the AI Engineer's workspace
# Download: huggingface.co/Qwen/Qwen2.5-Coder-32B-Instruct-GPTQ-Int4
QWEN_MODEL_PATH=/abr/{your_username}/shared_workspace/{name}_workspace/data/models/qwen32b-int4
