Bootstrap: docker
From: python:3.12-slim-bookworm

%labels
    Maintainer Luminara-SRE
    Project Luminara-AI-Foundation
    Description Heavy AI Dependencies (PyTorch, vLLM, Flash-Attn)

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive
    
    # --- SRE Standard Mount Anchors ---
    mkdir -p /data
    mkdir -p /workspace
    chmod 777 /data /workspace

    # 1. Core System & Compilation Foundations
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        gnupg \
        libpq-dev \
        build-essential \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir --upgrade pip
    export MAX_JOBS=4

    # ---------------------------------------------------------
    # HARDWARE PARITY FIX (NVIDIA Driver 525.105.17 + Python 3.12)
    # ---------------------------------------------------------
    
    echo "Installing PyTorch CUDA Foundation..."
    pip install --no-cache-dir torch==2.5.1 --index-url https://download.pytorch.org/whl/cu121

    echo "Installing pre-compiled Flash Attention..."
    export FLASH_WHEEL="https://github.com/Dao-AILab/flash-attention/releases/download/v2.7.4.post1/flash_attn-2.7.4.post1+cu12torch2.5cxx11abiFALSE-cp312-cp312-linux_x86_64.whl"
    pip install --no-cache-dir $FLASH_WHEEL

    # 2. Heavy, Slow-Moving AI Inference Engines
    cat > base_requirements.txt <<EOF
vllm==0.6.4
transformers>=4.48.0
accelerate>=1.3.0
sentence-transformers>=5.4.1
numpy>=1.26.4,<2.0.0
EOF

    echo "Installing Heavy Inference Libraries..."
    pip install --no-cache-dir -r base_requirements.txt
    rm base_requirements.txt
    
    echo "Luminara-SRE: TIER 1 BASE IMAGE COMPLETE ✅"