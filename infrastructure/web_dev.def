Bootstrap: docker
From: node:24-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Dashboard
    Tier Development
    Team_Size 5

%setup
    # Identical to Production: Pre-create anchors
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace

%environment
    # DEV PARITY: Same defaults, different NODE_ENV
    export PORT=${PORT:-3001}
    export NODE_ENV=development
    export DATA_PATH=/data
    
    export PNPM_HOME="/tmp/pnpm"
    export PATH="$PNPM_HOME:$PATH"
    export COREPACK_ENABLE_AUTO_PIN=0

%post
    set -e

    # SRE FIX: Added basic DX tools (git, nano, htop) for debugging
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        git \
        nano \
        htop \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    npm install -g pnpm@latest
    
    pnpm config set store-dir /workspace/.pnpm-store
    pnpm config set update-notifier false

    # SRE FIX: Nuke the massive NPM cache before compression
    npm cache clean --force
    
%runscript
    cd /workspace
    
    echo "------------------------------------------------"
    echo "🛠️ Luminara DEVELOPMENT Dashboard Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "📂 Data Source: $DATA_PATH"
    echo "------------------------------------------------"

    # DEV DIFFERENCE: We do not use --frozen-lockfile in dev
    # to allow teammates to add packages easily.
    # SRE FIX: The Human Fallback
    if [ $# -gt 0 ]; then
        # If the developer passed commands (like 'bash' or 'pnpm lint'), execute those
        exec "$@"
    else
        # SRE FIX: The Empty Workspace Trap Prevention
        if [ ! -f "package.json" ]; then
            echo "⚠️ WARNING: No package.json found in /workspace."
            echo "Please initialize your Next.js app or clone the repository."
            echo "Dropping you into an interactive shell..."
            exec /bin/bash
        fi

        # DEV DIFFERENCE: We do not use --frozen-lockfile in dev
        pnpm install

        # DEV DIFFERENCE: Launch Next.js in dev mode (hot reloading)
        exec pnpm dev --port $PORT --hostname 0.0.0.0
    fi

%help
    Luminara Development Dashboard
    ------------------------------
    This container is optimized for hot-reloading and debugging.
    It uses 'pnpm dev' and is mirrored to the Production SIF.