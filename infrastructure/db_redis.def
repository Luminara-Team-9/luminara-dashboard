Bootstrap: docker
From: redis:7-bookworm

%labels
    Maintainer Luminara-SRE
    Project Luminara-RUM
    Service Redis-Production
    Role Swetrix-Cache-And-Agent-State
    Tested

%environment
    export PORT=${PORT:-6379}
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    
    # 🛡️ Fallback Defaults (These will be overridden by your .env file)
    export REDIS_HOST=${REDIS_HOST:-0.0.0.0}
    export REDIS_MAXMEMORY=${REDIS_MAXMEMORY:-1024mb}
    export REDIS_MAXMEMORY_POLICY=${REDIS_MAXMEMORY_POLICY:-volatile-lru}

%post
    # SRE FIX 1: Restore PATH for the build environment
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export DEBIAN_FRONTEND=noninteractive

    # 🚦 VERTICAL PARITY: GHA Infrastructure Anchors
    mkdir -p /data
    mkdir -p /workspace
    mkdir -p /data/redis
    
    # SRE FIX 2: Bypassing the statvfs error for Singularity
    mkdir -p /tmp/apt-cache
    apt-get -o Dir::Cache::archives=/tmp/apt-cache update -o Acquire::Retries=3 
    apt-get -o Dir::Cache::archives=/tmp/apt-cache -o APT::Get::List-Cleanup="0" install -y --no-install-recommends -o Acquire::Retries=3 \
        ca-certificates \
        curl
    apt-get clean
    rm -rf /tmp/apt-cache

%runscript
    echo "------------------------------------------------"
    echo "🔴 Luminara RUM: REDIS Starting"
    echo "🌐 Port: $PORT | Bind: $REDIS_HOST | Data: /data/redis"
    echo "🧠 Policy: $REDIS_MAXMEMORY_POLICY (Protects AI State)"
    echo "------------------------------------------------"
    
    if [ -z "$REDIS_PASSWORD" ]; then
        echo "⚠️  WARNING: REDIS_PASSWORD is empty! Swetrix and LangGraph may fail to connect if they expect authentication."
    fi

    # SRE FIX 3: Direct data and PID to writable locations, bypassing read-only /var/run
    # SRE FIX 4: Dynamically map .env variables directly into the Redis start command
    
    if [ -n "$REDIS_PASSWORD" ]; then
        exec redis-server \
            --port "$PORT" \
            --bind "$REDIS_HOST" \
            --dir /data/redis \
            --dbfilename dump.rdb \
            --appendonly yes \
            --pidfile /tmp/redis.pid \
            --maxmemory "$REDIS_MAXMEMORY" \
            --maxmemory-policy "$REDIS_MAXMEMORY_POLICY" \
            --requirepass "$REDIS_PASSWORD"
    else
        exec redis-server \
            --port "$PORT" \
            --bind "$REDIS_HOST" \
            --dir /data/redis \
            --dbfilename dump.rdb \
            --appendonly yes \
            --pidfile /tmp/redis.pid \
            --maxmemory "$REDIS_MAXMEMORY" \
            --maxmemory-policy "$REDIS_MAXMEMORY_POLICY"
    fi

%help
    Luminara Production Redis (Dual Role: Swetrix Cache + AI Agent State)
    ---------------------------------------------------------------------
    Usage: 
    export SINGULARITYENV_REDIS_PASSWORD="your_secure_password"
    singularity run --bind /your/server/path/redis_data:/data redis_prod.sif