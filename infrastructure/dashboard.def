Bootstrap: docker
From: node:24.15.0-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Dashboard
    Tier Production
    Team_Size 5

%setup
    # Pre-create anchors for the SRE "Multi-Tenant" protocol
    # These must remain identical to Dev to ensure infrastructure parity
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace

%environment
    # SRE Port Offset Rule
    export PORT=${PORT:-3000}
    export NODE_ENV=production
    export DATA_PATH=/data
    
    # Pathing for pnpm
    export PNPM_HOME="/usr/local/share/pnpm"
    export PATH="$PNPM_HOME:$PATH"

%post
    set -e

    # Minimal system tools for Production (Removed procps to keep it slim)
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    npm install -g pnpm@latest
    
    # Configure pnpm for a shared environment
    pnpm config set store-dir /workspace/.pnpm-store

%runscript
    cd /workspace
    
    echo "🚀 Luminara PRODUCTION Dashboard Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "📂 Data Source: $DATA_PATH"
    echo "------------------------------------------------"

    # 1. Install dependencies (Production only to save space)
    # Using --frozen-lockfile ensures the build is predictable
    pnpm install --frozen-lockfile

    # 2. Build the Next.js application
    # This generates the optimized .next folder in the bound workspace
    pnpm build

    # 3. Start the production server
    # Bound to 0.0.0.0 for external access
    exec pnpm start --port $PORT --hostname 0.0.0.0

%help
    Luminara Production Dashboard
    ------------------------------
    This image runs the optimized Next.js build. 
    It is recommended to use a dedicated production branch of your code.