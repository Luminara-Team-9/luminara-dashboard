Bootstrap: docker
From: node:24.15.0-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Infrastructure
    Service LHCI-Development
    

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace

%environment
    # DEV PARITY: Offset port to 9002
    export PORT=${PORT:-9002}
    export NODE_ENV=development
    # SRE FIX: Removed the required variables so the GHA pipeline 
    # doesn't falsely assume installations.
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
%post
    # SRE FIX: Restore PATH and create mandatory Infrastructure Anchors
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export DEBIAN_FRONTEND=noninteractive
    # Create the folders the GHA Runner expects to see
    mkdir -p /data
    mkdir -p /workspace

    set -e
    # 🛠️ DEV TOOLS
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        htop \
        nano \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    npm install -g @lhci/server@latest

    # SRE FIX: Nuke the massive NPM cache before compression
    npm cache clean --force

%runscript
    cd /workspace
    
    echo "------------------------------------------------"
    echo "🏛️ Luminara DEVELOPMENT LHCI SERVER Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "------------------------------------------------"

    # SRE FIX: Dynamically capture the correct config flag
    LHCI_CONFIG=""
    if [ -f "/workspace/lighthouserc.dev.json" ]; then
        echo "[INFO] Detected lighthouserc.dev.json"
        LHCI_CONFIG="--config=/workspace/lighthouserc.dev.json"
    elif [ -f "/workspace/lighthouserc.json" ]; then
        echo "[INFO] Detected standard lighthouserc.json"
        LHCI_CONFIG="--config=/workspace/lighthouserc.json"
    else
        echo "CRITICAL ERROR: No LHCI configuration found in /workspace."
        exit 1
    fi

    # SRE FIX: The Human Fallback UX
    if [ $# -gt 0 ]; then
        exec "$@"
    else
        exec lhci server --port=$PORT $LHCI_CONFIG
    fi

%help
    Luminara Development LHCI Server
    --------------------------------
    Runs on Port 9002. Use this to receive audit results from 
    ephemeral 'audit_dev.sif' containers.