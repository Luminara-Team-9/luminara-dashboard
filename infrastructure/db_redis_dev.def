Bootstrap: docker
From: redis:7-bookworm

%labels
    Maintainer Luminara-SRE
    Project Luminara-RUM
    Service Redis-Development
    Team_Size 5
    Tested

%environment
    # SRE FIX: Use dynamic fallbacks for absolute flexibility
    export PORT=${PORT:-6380}
    export REDIS_DATA=${REDIS_DATA:-/data/redis_dev}
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

%post
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export DEBIAN_FRONTEND=noninteractive

    # 🚦 VERTICAL PARITY: GHA Infrastructure Anchors
    mkdir -p /data
    mkdir -p /workspace
    
    # DEV PARITY: Isolated data folder
    mkdir -p /data/redis_dev

    # SRE FIX: Bypassing the statvfs error & adding Dev Tools
    mkdir -p /tmp/apt-cache
    apt-get -o Dir::Cache::archives=/tmp/apt-cache update -o Acquire::Retries=3 
    apt-get -o Dir::Cache::archives=/tmp/apt-cache -o APT::Get::List-Cleanup="0" install -y --no-install-recommends -o Acquire::Retries=3 \
        ca-certificates \
        curl \
        htop \
        nano \
        procps
    apt-get clean
    rm -rf /tmp/apt-cache

%runscript
    echo "------------------------------------------------"
    echo "🔴 Luminara DEVELOPMENT: REDIS Starting"
    echo "🌐 Port: $PORT | Data: $REDIS_DATA"
    echo "------------------------------------------------"
    
    # SRE FIX: Use the dynamic variables in the execution command
    exec redis-server --port $PORT --dir $REDIS_DATA --dbfilename dump.rdb --appendonly yes --pidfile /tmp/redis_dev.pid