Bootstrap: docker
From: clickhouse/clickhouse-server:24.3

%labels
    Maintainer Luminara-SRE
    Project Luminara-RUM
    Service ClickHouse-Production
    Tested

%environment
    # SRE FIX: Restore dynamic port routing for the host machine
    export CLICKHOUSE_HTTP_PORT=${CLICKHOUSE_HTTP_PORT:-8123}
    export CLICKHOUSE_TCP_PORT=${CLICKHOUSE_TCP_PORT:-9000}
    export CLICKHOUSE_CONFIG=/etc/clickhouse-server/config.xml

    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

%post
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    

    # 🚦 GHA Infrastructure Anchors & Mount Points
    mkdir -p /data/clickhouse
    mkdir -p /workspace
    mkdir -p /logs/clickhouse
    mkdir -p /tmp/clickhouse
    mkdir -p /data/clickhouse_user_files
    mkdir -p /ch_socket

%startscript
    echo "------------------------------------------------"
    echo "📊 Luminara RUM: CLICKHOUSE Starting"
    echo "🌐 HTTP: $CLICKHOUSE_HTTP_PORT | Native: $CLICKHOUSE_TCP_PORT"
    echo "------------------------------------------------"
    
    # Executing with corrected paths matching the bound volumes
    exec clickhouse-server --config-file=$CLICKHOUSE_CONFIG -- \
        --http_port=$CLICKHOUSE_HTTP_PORT \
        --tcp_port=$CLICKHOUSE_TCP_PORT \
        --path=/data/clickhouse/ \
        --logger.log=/logs/clickhouse/clickhouse-server.log \
        --logger.errorlog=/logs/clickhouse/clickhouse-server.err.log \
        --tmp_path=/tmp/clickhouse/ \
        --user_files_path=/data/clickhouse/user_files/ \
        --pidfile=/tmp/clickhouse/clickhouse-server.pid

%help
    Luminara Production ClickHouse (Swetrix Stack)
    ----------------------------------------------
    Usage: singularity instance start --bind /host/rum_ch_data:/data/clickhouse clickhouse_prod.sif clickhouse_live