Bootstrap: docker
From: python:3.12-slim-bookworm

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends gcc g++ build-essential curl && apt-get clean

    pip install --no-cache-dir --upgrade pip
    
    # Install ONLY the massive, slow-moving AI dependencies here
    pip install --no-cache-dir \
        torch \
        vllm==0.6.4 \
        langchain==1.2.16 \
        transformers==5.7.0 \
        accelerate==1.13.0