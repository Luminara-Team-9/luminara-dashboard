Bootstrap: localimage
From: /abr/coss41/Luminara_App/images-prod/infrastructure_luminara_ai_base.sif

%labels
    Maintainer Luminara-SRE-Agent
    Project Luminara-AI-Remediation
    Tier Production-Agent
    Tested

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace
    mkdir -p ${SINGULARITY_ROOTFS}/usr/share/luminara-core

%environment
    # PRODUCTION STANDARDS
    export PORT=${PORT:-5000}
    export APP_ENV=production
    export DATA_PATH=/data
    export PIP_CACHE_DIR="/workspace/.pip-cache"
    export PIP_ROOT_USER_ACTION=ignore
    
    # Git & Persistence Configuration
    export XDG_CONFIG_HOME="/tmp/.config"
    export XDG_CACHE_HOME="/tmp/.cache"
    export GIT_CONFIG_NOSYSTEM=1
    export GIT_KNOWN_HOSTS_PATH="/workspace/.ssh/known_hosts"


%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # 1. Agent Logic Dependencies (Git is required for remediation commits)
    # SRE FIX: Removed dev-only tools like htop and nano for production security
    apt-get update -o Acquire::Retries=3 && apt-get install -y --no-install-recommends -o Acquire::Retries=3 \
        git \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # 2. GitHub CLI (Required for the Agent to open PRs)
    mkdir -p /etc/apt/keyrings
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null
    apt-get update && apt-get install -y gh && apt-get clean && rm -rf /var/lib/apt/lists/*


    # 3. Fast-Moving Application Logic & LangChain Stack
    # SRE FIX: Removed heavy AI libs (torch, vllm) as they are baked into the Base Image
    cat > requirements.txt <<EOF
# --- 1. Agent Logic & fallbacks ---
anthropic>=0.52.0
python-dotenv>=1.0.1
GitPython>=3.1.0
langgraph-sdk>=0.3.13
ormsgpack>=1.12.2

# --- 2. Data & Analytics (Validation Layer) ---
pandas>=2.3.1
scikit-learn>=1.7.0

# --- 3. Utilities & Networking (The missing layer) ---
requests>=2.33.1
aiohttp>=3.11.2
tqdm>=4.67.3
psutil>=6.1.0
redis>=5.3.0
rich>=13.9.4

# --- 4. Verification Engine ---
playwright>=1.58.0
lighthouse-python-plus==1.2.0
EOF

    echo "Installing fast-moving Production AI Tooling..."
    pip install --no-cache-dir -r requirements.txt
    rm requirements.txt

    # 4. Verification Engine (Playwright)
    # Required for the Agent to audit its own code patches before PR creation
    echo "Installing Headless Browser Binaries..."
    playwright install chromium --with-deps
    
    echo "Luminara-SRE: PRODUCTION AI Agent Container Hardening Complete ✅"

%runscript
    cd /workspace
    echo "------------------------------------------------"
    echo "🚀 Luminara PURE AI AGENT Starting"
    echo "🌐 Mode: $APP_ENV | Port: $PORT"
    echo "------------------------------------------------"
    
    # SRE FIX: Pure, stateless execution. No interactive shell fallbacks.
    exec python -m luminara_core.remediation_agent.run_agent --port $PORT