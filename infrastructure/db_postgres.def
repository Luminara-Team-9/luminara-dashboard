Bootstrap: docker
From: postgres:15.6-bookworm

%labels
    Maintainer Luminara-SRE
    Project Luminara-Infrastructure
    Service Database-Production
    Hardware ABRM02-ABR-COSS41
    Tested

%environment
    export PGPORT=${PGPORT:-5432}
    # SRE RULE: All data MUST be in a persistent bound folder
    export PGDATA=/data/postgres
    # SRE FIX: Bypasses read-only /var/run for socket locks
    export PGSOCKETS=/tmp
    export PATH="/usr/lib/postgresql/15/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

%post
    # SRE FIX 1: Restore the PATH immediately
    # This prevents the "mkdir: not found" error by telling the shell where binaries live.
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export DEBIAN_FRONTEND=noninteractive

    set -e

    # SRE FIX 2: Bypassing the statvfs disk space error
    # We tell apt to use /tmp for its archives so it doesn't get confused by the overlay.
    mkdir -p /tmp/apt-cache
    
    apt-get -o Dir::Cache::archives=/tmp/apt-cache update -o Acquire::Retries=3
    
    # SRE FIX 3: Disable disk space check and install tools
    apt-get -o Dir::Cache::archives=/tmp/apt-cache -o APT::Get::List-Cleanup="0" install -y --no-install-recommends -o Acquire::Retries=3 \
        ca-certificates \
        curl
        
    apt-get clean
    rm -rf /tmp/apt-cache

    # SRE FIX: Align the mount point with PGDATA and create the GHA anchors
    mkdir -p /data/postgres
    mkdir -p /workspace

    echo "Luminara-SRE: Postgres Dev Hardening Complete ✅"

%startscript
    # ------------------------------------------------------------------
    # PRODUCTION BOOTSTRAP PROTOCOL
    # ------------------------------------------------------------------
    DB_USER=${POSTGRES_USER:-coss41}
    
    # 1. Automatic Initialization (Runs only if /data is empty)
    if [ ! -f "$PGDATA/PG_VERSION" ]; then
        if [ -z "$POSTGRES_PASSWORD" ]; then
            echo "CRITICAL ERROR: POSTGRES_PASSWORD not set. Aborting initialization."
            exit 1
        fi
        echo "🐘 First-time boot: Initializing Production Database Cluster..."
        # SRE FIX: POSIX-compliant password injection (No Bashisms)
        echo "$POSTGRES_PASSWORD" > /tmp/pg_pw.txt
        # Add the -U flag here!
        initdb -D "$PGDATA" -U "$DB_USER" --auth=md5 --pwfile=/tmp/pg_pw.txt
        rm /tmp/pg_pw.tx
    fi

    echo "------------------------------------------------"
    echo "🐘 Luminara PRODUCTION POSTGRESQL Starting"
    echo "🌐 Port: $PGPORT | Socket: /tmp"
    echo "------------------------------------------------"

    # 2. Execution (Hardened for Singularity/No-Sudo environments)
    # -k points the Unix Socket to /tmp to avoid read-only /var/run crashes
    exec postgres -D "$PGDATA" -k "$PGSOCKETS" -p $PGPORT

%help
    Luminara Production PostgreSQL
    ------------------------------
    Stripped of all dev tools for maximum security and performance.
    Requires environment variable: POSTGRES_PASSWORD
    
    To run:
    singularity instance start --env-file .env.db \
                               --bind /path/to/persistent/storage:/data \
                               postgres_prod.sif postgres_live