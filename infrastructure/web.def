Bootstrap: docker
From: node:24-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Dashboard
    Tier Production

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace

%environment
    export PORT=${PORT:-3000}
    export NODE_ENV=production
    export DATA_PATH=/data
    
    export PNPM_HOME="/tmp/pnpm"
    export PATH="$PNPM_HOME:$PATH"

%post
    set -e

    # Install system tools
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    npm install -g pnpm@latest
    
    # SRE FIX: Install PM2 for robust process management
    npm install -g pm2
    
    npm cache clean --force

%runscript
    # 1. Navigate deep into the monorepo structure
    cd /workspace/1_dashboard_app
    
    echo "------------------------------------------------"
    echo "🚀 Luminara PRODUCTION Dashboard Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "------------------------------------------------"

    # 2. Instant validation
    if [ ! -d ".next" ]; then
        # SRE FIX: Updated the error log to point to the correct monorepo path
        echo "CRITICAL ERROR: No compiled Next.js build found in /workspace/1_dashboard_app/.next"
        echo "Did the CI/CD pipeline correctly sync the 1_dashboard_app directory?"
        exit 1
    fi

    # 3. PM2 Execution
    exec pm2-runtime start npm --name "luminara-dashboard-prod" -- run start -- -p $PORT

%help
    Luminara Production Dashboard
    ------------------------------
    This image is strictly for SERVING compiled Next.js code.
    You must run `pnpm install` and `pnpm build` on the host machine (or via the CI/CD pipeline) 
    BEFORE launching this container.