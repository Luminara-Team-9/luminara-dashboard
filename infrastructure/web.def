Bootstrap: docker
From: node:24-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Dashboard
    Tier Production-Pure
    Tested

# ---------------------------------------------------------
# 📦 INJECT SOURCE CODE
# Singularity copies these from your GitHub runner workspace 
# directly into the container's internal /workspace
# ---------------------------------------------------------
%files
    ./1_dashboard_app /workspace/1_dashboard_app
    ./0_shared_packages /workspace/0_shared_packages
    ./pnpm-workspace.yaml /workspace/pnpm-workspace.yaml
    ./package.json /workspace/package.json
    ./pnpm-lock.yaml /workspace/pnpm-lock.yaml

    # SRE FIX: Inject the lockfile so frozen-lockfile has a blueprint to read
    ./pnpm-lock.yaml /workspace/pnpm-lock.yaml

%environment
    export PORT=${PORT:-3001}
    export NODE_ENV=production
    export DASHBOARD_PERFORMANCE_API_URL=${DASHBOARD_PERFORMANCE_API_URL:-http://127.0.0.1:4000/dashboard/performance}
    export PNPM_HOME="/tmp/pnpm"
    export PATH="$PNPM_HOME:$PATH"

# ---------------------------------------------------------
# 🛠️ INTERNAL BUILD PHASE
# This happens ONCE when the .sif file is being created.
# ---------------------------------------------------------
%post
    set -e
    export NODE_ENV=production

    # 1. Install system tools
    apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # 2. Install Global JS Tools
    npm install -g pnpm@latest
    
    # 3. Build the Application INSIDE the Container
    cd /workspace
    echo "📦 Installing Dependencies Internally..."
    pnpm install --frozen-lockfile

    echo "🏗️ Building Next.js Internally..."
    pnpm --filter ./1_dashboard_app build
    
    # 🚨 SRE FIX: Finalizing Standalone Assets
    # In a pnpm workspace, the standalone folder is usually at:
    # /workspace/1_dashboard_app/.next/standalone

    echo "🎯 Finalizing standalone assets..."
    cd /workspace/1_dashboard_app
    
    if [ -d "public" ]; then
        cp -r public .next/standalone/1_dashboard_app/public
    else
        echo "ℹ️ Skipping 'public': Not found."
    fi

    if [ -d ".next/static" ]; then
        cp -r .next/static .next/standalone/1_dashboard_app/.next/static
    else
        echo "ℹ️ Skipping '.next/static': Not found."
    fi

    # Optional: Clean up workspace to reduce .sif size
    # The standalone folder contains everything needed to run.
    npm cache clean --force

# ---------------------------------------------------------
# 🚀 RUN PHASE
# This happens every time you start the container.
# ---------------------------------------------------------
%startscript
    echo "------------------------------------------------"
    echo "🚀 Luminara PURE PRODUCTION Dashboard Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "------------------------------------------------"

    # 🚨 SRE FIX: Launch using node directly from the standalone entry point.
    # Note: In a workspace, the server.js expects to be run from the root 
    # of the standalone folder to find its node_modules.
    cd /workspace/1_dashboard_app/.next/standalone
    
    echo "[..] Target: 1_dashboard_app/server.js"
    exec node 1_dashboard_app/server.js --port ${PORT} --hostname 0.0.0.0
