Bootstrap: docker
From: node:24-slim

%labels
    Maintainer Luminara-SRE
    Project Luminara-Dashboard
    Tier Production

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/data
    mkdir -p ${SINGULARITY_ROOTFS}/workspace

%environment
    export PORT=${PORT:-3000}
    export NODE_ENV=production
    export DATA_PATH=/data
    
    export PNPM_HOME="/tmp/pnpm"
    export PATH="$PNPM_HOME:$PATH"

%post
    set -e

    # Install system tools
    apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    npm install -g pnpm@latest
    
    # SRE FIX: Install PM2 for robust process management
    npm install -g pm2
    
    npm cache clean --force

%runscript
    cd /workspace
    
    echo "------------------------------------------------"
    echo "🚀 Luminara PRODUCTION Dashboard Starting"
    echo "🌐 Mode: $NODE_ENV | Port: $PORT"
    echo "------------------------------------------------"

    # SRE FIX: Instant validation
    if [ ! -d "/workspace/.next" ]; then
        echo "CRITICAL ERROR: No compiled Next.js build found in /workspace/.next"
        echo "Did you run 'pnpm build' on the host before starting the container?"
        exit 1
    fi

    # SRE FIX: Use PM2 to run the production server. 
    # PM2 automatically restarts the node process if it crashes, without rebooting the whole container.
    exec pm2-runtime start npm --name "luminara-dashboard" -- run start -- -p $PORT

%help
    Luminara Production Dashboard
    ------------------------------
    This image is strictly for SERVING compiled Next.js code.
    You must run `pnpm install` and `pnpm build` on the host machine (or CI pipeline) 
    BEFORE launching this container.